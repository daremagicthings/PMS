// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ──────────────────────────────────────────────

enum Role {
  SUPER_ADMIN // System owner (you)
  ADMIN       // Organization manager
  RESIDENT    // Apartment resident
}

enum InvoiceStatus {
  PENDING
  PAID
  CANCELLED
}

enum TicketStatus {
  NEW
  IN_PROGRESS
  RESOLVED
}

enum NotificationType {
  TICKET_UPDATE
  NEW_COMMENT
  INVOICE
  ANNOUNCEMENT
  SYSTEM
}

enum PollStatus {
  ACTIVE
  CLOSED
}

// ─── MODELS ─────────────────────────────────────────────

/// Represents a distinct Property Management Company / СӨХ Entity (Multi-Tenant).
model Organization {
  id          String   @id @default(uuid())
  name        String   @unique
  contactInfo String?
  isActive    Boolean  @default(true)

  users            User[]
  apartments       Apartment[]
  announcements    Announcement[]
  workPlans        WorkPlan[]
  financialReports FinancialReport[]
  polls            Poll[]
  staticContents   StaticContent[]
  contacts         Contact[]
  faqs             Faq[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("organizations")
}

/// Represents an Admin or Resident user in the system.
model User {
  id           String   @id @default(uuid())
  email        String?  @unique
  phone        String?  @unique
  name         String
  role         Role     @default(RESIDENT)
  passwordHash    String
  expoPushToken   String?

  /// E-Barimt Receipt Type: CITIZEN or ENTITY
  ebarimtType     String   @default("CITIZEN")
  /// E-Barimt Registry Number (Company TTDD or Person ID)
  ebarimtRegNo    String?

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  apartment   Apartment? @relation(fields: [apartmentId], references: [id], onDelete: SetNull)
  apartmentId String?

  tickets        Ticket[]
  announcements  Announcement[]
  ticketComments TicketComment[]
  notifications  Notification[]
  pollVotes      PollVote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

/// Represents a physical unit within a building (apartment, musar, or basement).
model Apartment {
  id           String @id @default(uuid())
  buildingName String
  entrance     String
  floor        Int
  unitNumber   String

  /// Category: "APARTMENT" | "MUSAR" | "BASEMENT" | "PARKING" | "STORAGE"
  unitType       String    @default("APARTMENT")
  /// Owner of the unit (nullable — may not have a registered owner)
  ownerId        String?
  /// Tenant currently leasing the unit (nullable)
  tenantId       String?
  /// Lease period start date
  leaseStartDate DateTime?
  /// Lease period end date
  leaseEndDate   DateTime?
  /// External contract reference ID
  contractId     String?

  /// Parent linked Apartment (Used for nested Parking/Storage assignments)
  parentApartmentId String?
  parentApartment   Apartment?  @relation("ApartmentHierarchy", fields: [parentApartmentId], references: [id])
  childApartments   Apartment[] @relation("ApartmentHierarchy")

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  residents User[]
  invoices  Invoice[]
  tickets   Ticket[]
  vehicles  Vehicle[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([buildingName, entrance, unitNumber])
  @@index([unitType])
  @@map("apartments")
}

/// Represents a monthly fee invoice linked to an apartment.
model Invoice {
  id             String        @id @default(uuid())
  amount         Float
  penaltyAmount  Float         @default(0)
  description    String?
  status         InvoiceStatus @default(PENDING)
  dueDate        DateTime
  paidAt         DateTime?
  qpayUrl        String?
  qpayInvoiceId  String?
  ebarimtId      String?
  lotteryNumber  String?
  ebarimtQrCode  String?

  apartment   Apartment @relation(fields: [apartmentId], references: [id], onDelete: Restrict)
  apartmentId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bankStatements BankStatement[]

  @@index([status])
  @@index([dueDate])
  @@index([apartmentId])
  @@map("invoices")
}

/// Represents an external bank statement record used for invoice reconciliation.
model BankStatement {
  id              String   @id @default(uuid())
  date            DateTime
  amount          Float
  description     String
  status          String   @default("PENDING") // PENDING, MATCHED

  matchedInvoiceId String?
  matchedInvoice   Invoice? @relation(fields: [matchedInvoiceId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@map("bank_statements")
}

/// Represents a maintenance request or complaint submitted by a resident.
model Ticket {
  id          String       @id @default(uuid())
  title       String
  description String
  imageUrl    String?
  status      TicketStatus @default(NEW)

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  apartment   Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
  apartmentId String

  comments TicketComment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
  @@map("tickets")
}

/// Represents an announcement or meeting notice created by an Admin.
model Announcement {
  id          String  @id @default(uuid())
  title       String
  content     String
  meetingLink String?

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id], onDelete: Cascade)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("announcements")
}

/// Represents a comment on a ticket, written by an Admin or Resident.
model TicketComment {
  id      String @id @default(uuid())
  content String

  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  ticketId String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ticket_comments")
}

/// Notification record sent to a user for various events.
model Notification {
  id      String           @id @default(uuid())
  title   String
  message String
  type    NotificationType @default(SYSTEM)
  isRead  Boolean          @default(false)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@map("notifications")
}

// ─── TRANSPARENCY & REPORTING ───────────────────────────

enum WorkPlanStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
}

/// Represents a work plan item for building maintenance or improvements.
model WorkPlan {
  id           String         @id @default(uuid())
  title        String
  description  String
  status       WorkPlanStatus @default(PLANNED)
  expectedDate DateTime
  imageUrl     String?

  /// Category: "REGULAR" | "SCHEDULED" | "AD_HOC"
  category     String         @default("REGULAR")

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("work_plans")
}

/// Represents a vehicle registered to an apartment.
model Vehicle {
  id           String    @id @default(uuid())
  licensePlate String    @unique
  makeModel    String

  apartment   Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
  apartmentId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("vehicles")
}

/// Represents a monthly financial transparency report.
model FinancialReport {
  id           String  @id @default(uuid())
  month        Int
  year         Int
  totalIncome  Float
  totalExpense Float
  description  String?
  imageUrl     String?

  transactions FinancialTransaction[]

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([month, year, organizationId])
  @@map("financial_reports")
}

/// Represents a detailed financial transaction (Income or Expense) within a monthly report.
model FinancialTransaction {
  id             String   @id @default(uuid())
  date           DateTime
  amount         Float
  receiverSender String
  description    String
  type           String   @default("INCOME") // INCOME, EXPENSE

  reportId       String
  report         FinancialReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([date])
  @@map("financial_transactions")
}

/// Represents a digital vote/poll created by an Admin.
model Poll {
  id          String     @id @default(uuid())
  title       String
  description String?
  status      PollStatus @default(ACTIVE)
  endDate     DateTime?

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  options PollOption[]
  votes   PollVote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("polls")
}

/// One selectable option within a poll.
model PollOption {
  id   String @id @default(uuid())
  text String

  poll   Poll   @relation(fields: [pollId], references: [id], onDelete: Cascade)
  pollId String

  votes PollVote[]

  @@map("poll_options")
}

/// Records a single vote cast by a user. One vote per user per poll.
model PollVote {
  id String @id @default(uuid())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  poll   Poll   @relation(fields: [pollId], references: [id], onDelete: Cascade)
  pollId String

  option   PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  optionId String

  createdAt DateTime @default(now())

  @@unique([userId, pollId])
  @@map("poll_votes")
}

// ─── DYNAMIC CONTENT ────────────────────────────────────

/// Represents single-page static content (Rules, Inquiries, etc.)
model StaticContent {
  id      String @id @default(uuid())
  /// Type of content, e.g., "RULES", "INQUIRIES"
  type    String 
  title   String
  content String

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([type, organizationId])
  @@map("static_content")
}

/// Represents a directory of important contacts (Plumber, Electrician, etc.)
model Contact {
  id          String   @id @default(uuid())
  name        String
  phone       String
  role        String
  description String?

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([organizationId])
  @@map("contacts")
}

/// Represents Frequently Asked Questions
model Faq {
  id       String @id @default(uuid())
  question String
  answer   String
  order    Int    @default(0)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@map("faqs")
}
